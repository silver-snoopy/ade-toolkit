repos:
{% if not is_windows %}
  # Security scanning (not supported on Windows)
  - repo: https://github.com/returntocorp/semgrep
    rev: v1.117.0
    hooks:
      - id: semgrep
        args: ['--config', 'p/default']
{% endif %}

{% if config.scanning.ruff.enabled %}
  # Python linting + formatting
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.11.4
    hooks:
      - id: ruff
        args: ['--fix']
      - id: ruff-format
{% endif %}

{% if config.scanning.prettier.enabled %}
  # JavaScript/TypeScript formatting (local — avoids mirror version lag)
  - repo: local
    hooks:
      - id: prettier
        name: prettier
        entry: npx prettier --write --ignore-unknown
        language: system
        types_or: [javascript, ts, tsx, css, html, markdown, json, yaml]
{% endif %}

{% if config.scanning.eslint.enabled %}
  # ESLint (local — avoids mirror version lag)
  - repo: local
    hooks:
      - id: eslint
        name: eslint
        entry: npx eslint --fix
        language: system
        types_or: [javascript, ts, tsx]
{% endif %}

  # Secret detection
  - repo: https://github.com/Yelp/detect-secrets
    rev: v1.5.0
    hooks:
      - id: detect-secrets
